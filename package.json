{
  "name": "p2k2",
  "private": true,
  "engines": {
    "npm": ">=9.8.1",
    "node": ">=16.20.0",
    "yarn": ">=1.22.17"
  },
  "scripts": {
    "build": "run-s clean && run-p build:*",
    "build:src": "node index.mjs",
    "build:typescript": "npx tsc",
    "clean": "rimraf dist",
    "dev": "run-s clean && run-p dev:*",
    "dev:src": "node index.mjs -w",
    "dev:typescript": "npx tsc -w",
    "lint": "run-p lint:*",
    "lint:typescript": "npx tsc",
    "lint:js": "eslint ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.243",
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.1",
    "rimraf": "^5.0.1",
    "typescript": "^5.1.6",
    "watcher": "^2.3.0"
  }
}
