{
  "name": "P2K2",
  "description": "Improved and user-friendly version of the P2000 notifications",
  "version": "0.1",
  "manifest_version": 3,
  "permissions": ["notifications", "alarms", "scripting", "tabs"],
  "host_permissions": ["*://*:*/*", "*://webservice-v3.112-nederland.nl/*"],
  "web_accessible_resources": [
    {
      "resources": ["/assets/notification.wav"],
      "matches": ["*://*:*/*"]
    }
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "P2K2",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/favicon-16-light.png",
      "24": "images/favicon-24-light.png",
      "32": "images/favicon-32-light.png",
      "48": "images/favicon-48-light.png",
      "128": "images/favicon-128-light.png"
    }
  },
  "icons": {
    "32": "images/favicon-32-dark.png",
    "128": "images/favicon-128-dark.png"
  }
}
